# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Node
node_modules/
.next/
out/
*.tsbuildinfo
playwright-report/
test-results/
.playwright/

# Секреты и локальная конфигурация
.env
.env.local
.env.*.local
!.env.example

# Локальные данные, которые не версионируются
data/local/
data/cache/
*.log

# Дампы базы. Содержат персональные данные — БИН и ИИН организаций и
# получателей субсидий. В репозиторий не попадают ни при каких условиях:
# один неосторожный `git add -A` сделал бы их публичными навсегда.
dist/
*.dump
*.dump.txt

# Книги комплекта ДЭР. Immutable-исходники живут вне репозитория, путь к ним
# задаётся переменной SOURCE_DATA_DIR.
data/source/

# Артефакты сборки отчётов
exports/

# Рабочие копии, создаваемые агентами
.claude/worktrees/

# ОС и редакторы
Thumbs.db
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
