# Единый перевод строки в репозитории — LF, независимо от ОС разработчика.
* text=auto eol=lf

# Бинарные и уже нормализованные форматы не трогать.
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.xlsx binary
*.docx binary
*.zip binary
*.pdf binary

# Скрипты Windows должны сохранять CRLF, иначе PowerShell ругается.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf
*.bat text eol=crlf
*.sh text eol=lf

# Файлы с зафиксированным в PROVENANCE.md SHA-256: байты неприкосновенны,
# нормализация LF ломает проверку происхождения (SHA не сходится на свежем клоне).
data/boundaries/*.geojson -text
data/boundaries/region-aliases-8-3.json -text
