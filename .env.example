# Пример конфигурации. Скопируйте в `.env` и поправьте под себя.
#
#     cp .env.example .env
#
# Файл `.env` в репозиторий не попадает — он в .gitignore.

# --- Режим работы ------------------------------------------------------------

# dev | test | prod. В prod пустой JWT_SECRET роняет запуск: забытая
# переменная не должна молча превращаться в уязвимость.
ENVIRONMENT=dev
DEBUG=false

# --- База данных -------------------------------------------------------------

# При запуске через Docker Compose имя хоста — `db`, порт внутренний 5432.
# При локальном запуске без Docker — 127.0.0.1 и порт из setup-скрипта (5433).
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/riskmap

# Пароль базы для Docker Compose. В рабочем контуре замените.
POSTGRES_PASSWORD=postgres

# --- Секреты -----------------------------------------------------------------

# Обязателен вне dev. Сгенерировать:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Время жизни сессии в минутах.
ACCESS_TOKEN_TTL_MINUTES=60

# Блокировка после серии неудачных входов — требование ТЗ по безопасности.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PASSWORD_MIN_LENGTH=12

# --- Исходные данные ---------------------------------------------------------

# Каталог с книгами комплекта ДЭР. Только чтение: импорт никогда не пишет
# в него и проверяет неизменность файлов по SHA-256.
#
# Без этого каталога система поднимется и будет работать на уже загруженных
# данных; повторный импорт станет невозможен.
SOURCE_DATA_DIR=/data/source

# --- Сеть --------------------------------------------------------------------

# Через запятую. `localhost` и `127.0.0.1` — разные источники для браузера,
# и разрешение одного не действует на другой.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Предел размера загружаемого файла в мастере импорта.
MAX_UPLOAD_MB=50

# --- Frontend ----------------------------------------------------------------

# Адрес API, который видит браузер. Внутреннее имя контейнера сюда не годится:
# запрос уходит из браузера, а не из контейнера.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8100/api/v1

# Адрес стиля карты. Пусто — карта рисует только собственные границы на
# однотонном фоне и работает без интернета. Внешние публичные сервисы сюда
# подставлять не следует: это утечка запросов наружу и зависимость, которой
# в закрытом контуре не будет.
NEXT_PUBLIC_MAP_STYLE_URL=
